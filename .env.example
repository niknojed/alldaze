# Environment variables for AllDazeWork.
# Copy this file to `.env.local` and fill in real values (that file is gitignored).

# ── Audit request form (/api/audit-request) — Gmail SMTP via nodemailer ──
# The Gmail / Google Workspace address that generated the App Password.
# Must be a full address, e.g. design@alldazework.com
SMTP_USER=
# A 16-character Google App Password (spaces are fine). Requires 2-Step
# Verification on the account. Generate at https://myaccount.google.com/apppasswords
SMTP_PASS=
# Where audit-request emails are delivered.
NOTIFY_TO=design@alldazework.com

# ── Talon chatbot (/api/chat) ──
# Anthropic API key — required only if the chat feature is used.
ANTHROPIC_API_KEY=
