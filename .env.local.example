# ============================================================================
# AllDazeWork contact form — environment variables
# ============================================================================
# Copy this file to .env.local and fill in the values for your chosen provider.
# .env.local is gitignored — never commit real secrets.
#
# Pick ONE provider via EMAIL_PROVIDER. Leave the other provider's vars empty.

# resend | gmail
EMAIL_PROVIDER=resend

# Where contact form submissions are delivered
[email protected]

# ── Resend (when EMAIL_PROVIDER=resend) ──
# Use onboarding@resend.dev for initial testing; switch to a verified domain
# address (e.g. hello@alldaze.studio) for production.
[email protected]
RESEND_API_KEY=

# ── Gmail SMTP (when EMAIL_PROVIDER=gmail) ──
# GMAIL_USER is the sending account; GMAIL_APP_PASSWORD is a 16-char App Password
# (spaces stripped). CONTACT_FROM_EMAIL defaults to GMAIL_USER if unset.
[email protected]
GMAIL_APP_PASSWORD=
